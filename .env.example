# PostgreSQL
POSTGRES_USER=briefing
POSTGRES_PASSWORD=briefing
POSTGRES_DB=briefing
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
APP_ENV=local
DEBUG=true
# DATABASE_URL ниже — для запуска backend ВНЕ Docker (host = localhost).
# В Docker этот localhost-вариант НЕ используется: docker-compose.yml переопределяет
# DATABASE_URL и подключается к Postgres по имени сервиса `db` (host = db).
DATABASE_URL=postgresql+psycopg://briefing:briefing@localhost:5432/briefing
CORS_ORIGINS=http://localhost:5173

# LLM (OpenAI-compatible Chat Completions API, endpoint POST {LLM_BASE_URL}/chat/completions)
# LLM_API_KEY и LLM_MODEL обязательны для AI-эндпоинтов (analyze / generate / regenerate-section).
# Если LLM_API_KEY или LLM_MODEL не заданы — эти эндпоинты возвращают 503 (остальное работает).
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
