# Production env template для docker-compose.prod.yml.
# Скопировать в .env.prod и заполнить РЕАЛЬНЫМИ значениями (НЕ коммитить .env.prod).
# Реальные секреты — через secret-manager/host-env, не в репозитории.

# --- Postgres (контейнер БД в prod-compose) ---
POSTGRES_USER=briefing
POSTGRES_PASSWORD=          # СЕКРЕТ — задать сильный пароль
POSTGRES_DB=briefing

# --- Backend ---
APP_ENV=production
DEBUG=false
# В prod-compose backend подключается к Postgres по сервис-имени `db`.
# (vs dev: вне Docker host=localhost.)
DATABASE_URL=postgresql+psycopg://briefing:CHANGE_ME@db:5432/briefing

# CORS: при same-origin (nginx проксирует /api) не требуется. Если фронт и API
# на разных доменах — указать реальный домен фронтенда, например:
# CORS_ORIGINS=https://briefs.example.com
CORS_ORIGINS=

# --- LLM (OpenAI-compatible) ---
# Без LLM_API_KEY / LLM_MODEL AI-эндпоинты возвращают 503 (остальное работает).
LLM_API_KEY=              # СЕКРЕТ
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=                # точный id, чувствителен к регистру (см. GET {LLM_BASE_URL}/models)
LLM_TIMEOUT_SECONDS=60

# --- Frontend (build-time) ---
# Пусто → клиент шлёт относительные /api (same-origin), nginx проксирует на backend.
VITE_API_URL=
