# Yandex production env template for docker-compose.yandex.yml.
# Copy to the repo root as .env.prod on the VM and fill REAL values.
# .env.prod is gitignored — never commit it. Keep real secrets in a secret
# manager / host env, not in the repository.
#
#   cp deploy/.env.prod.example .env.prod   # then edit

# --- Container registry & image tag (used for compose image interpolation) ---
# Yandex Container Registry path, e.g. cr.yandex/<registry-id>
YC_REGISTRY=cr.yandex/CHANGE_ME
# Image tag to run. Normally set by deploy/deploy.sh (e.g. a git short SHA or
# a version). A value here is the default when no tag is passed to the script.
IMAGE_TAG=latest

# --- Backend ---
APP_ENV=production
DEBUG=false

# Yandex Managed PostgreSQL DSN (NO local db in this stack).
# Host = the Managed PostgreSQL FQDN; port 6432; SSL is required.
#   sslmode=require        — encrypts, does not verify the CA (simplest).
#   sslmode=verify-full    — recommended; needs the Yandex CA mounted into the
#                            backend container (see docs/deploy-yandex-cloud.md).
DATABASE_URL=postgresql+psycopg://briefing:CHANGE_ME@rc1a-xxxxxxxx.mdb.yandexcloud.net:6432/briefing?sslmode=require

# CORS: same-origin via the reverse proxy needs nothing here. Set the real
# frontend domain only if the SPA and API are served from different origins.
# CORS_ORIGINS=https://briefs.example.com
CORS_ORIGINS=

# --- LLM (OpenAI-compatible) ---
# Without LLM_API_KEY / LLM_MODEL the AI endpoints return 503; the rest works.
LLM_API_KEY=              # SECRET
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=                # exact production model id (case-sensitive)
LLM_TIMEOUT_SECONDS=60

# --- Frontend (build-time only; informational) ---
# VITE_API_URL is baked into the frontend image at BUILD time (Dockerfile.prod
# sets it empty → the SPA uses relative /api, proxied by the reverse proxy).
# It is NOT read at runtime, so it does not need a value here.
# VITE_API_URL=
